import { DequeIterator } from './DequeIterator.cjs';
import { DoublyLinkedList } from './DoublyLinkedList.cjs';

/**
 * DoublyLinkedList backed double ended queue
 * implements just enough to keep the Pool
 */
declare class Deque<T> {
    protected _list: DoublyLinkedList<T>;
    constructor();
    /**
     * removes and returns the first element from the queue
     * @return [description]
     */
    shift(): T | null;
    /**
     * adds one elemts to the beginning of the queue
     * @param  {any} element [description]
     * @return           [description]
     */
    unshift(element: T): void;
    /**
     * adds one to the end of the queue
     * @param  {any} element [description]
     * @return          [description]
     */
    push(element: T): void;
    /**
     * removes and returns the last element from the queue
     */
    pop(): T | null;
    [Symbol.iterator](): DequeIterator<T>;
    iterator(): DequeIterator<T>;
    reverseIterator(): DequeIterator<T>;
    /**
     * get a reference to the item at the head of the queue
     * @return [description]
     */
    get head(): T | null;
    /**
     * get a reference to the item at the tail of the queue
     * @return  [description]
     */
    get tail(): T | null;
    get length(): number;
}

export { Deque };
